{
  "manifest_version": 3,
  "name": "TabLens",
  "version": "1.0.0",
  "description": "Search all open tabs by full-text page content using a fast, privacy-first local index.",

  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
  "<all_urls>"
],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "toggle-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle the TabLens search overlay"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["overlay.html", "overlay.css", "overlay.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}